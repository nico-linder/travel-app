<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="4.6.0">
  <bpmn:process id="vibes-suggestion" name="Vibes Suggestion" isExecutable="true" camunda:historyTimeToLive="P180D">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Activity_DetermineSuggestions" />
    <bpmn:scriptTask id="Activity_DetermineSuggestions" name="Determine Suggestions" scriptFormat="javascript">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:script>
        var relations = {
          'Natural': ['beaches', 'mountains', 'forests', 'waterfalls', 'lakes'],
          'Cultural': ['museums', 'theatres', 'urban_art', 'festivals', 'cinemas'],
          'Historic': ['castles', 'fortifications', 'monuments', 'archaeology', 'ruins'],
          'Architecture': ['skyscrapers', 'bridges', 'historic_architecture'],
          'Other': ['cafes', 'restaurants', 'shops', 'amusement_parks'],
          'beaches': ['islands', 'reefs', 'diving'],
          'mountains': ['hiking', 'viewpoints', 'climbing'],
          'museums': ['art_galleries', 'history_museums', 'science_museums'],
          'castles': ['palaces', 'manors', 'chateaus'],
          'restaurants': ['bars', 'wineries', 'local_food']
        };
        var currentVibe = execution.getVariable('currentVibe');
        var suggested = relations[currentVibe] || [];
        execution.setVariable('suggestedVibes', JSON.stringify(suggested));
      </bpmn:script>
    </bpmn:scriptTask>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Activity_DetermineSuggestions" targetRef="EndEvent_1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="vibes-suggestion">
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="370" y="117" />
        <di:waypoint x="422" y="117" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="215" y="117" />
        <di:waypoint x="270" y="117" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="_BPMNShape_StartEvent_2" bpmnElement="StartEvent_1">
        <dc:Bounds x="179" y="99" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="185" y="142" width="24" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1p4q3m4_di" bpmnElement="Activity_DetermineSuggestions">
        <dc:Bounds x="270" y="77" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="422" y="99" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="430" y="142" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
