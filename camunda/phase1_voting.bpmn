        <di:waypoint x="470" y="525" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="BPMNShape_1jv4cb1" bpmnElement="Participant_1mor060" isHorizontal="true">
        <dc:Bounds x="151" y="80" width="729" height="250" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
