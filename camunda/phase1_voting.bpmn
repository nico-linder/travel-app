      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Init_di" bpmnElement="Activity_Init">
        <dc:Bounds x="290" y="510" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_Catch_Vote_di" bpmnElement="Event_Catch_Vote">
        <dc:Bounds x="550" y="532" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="533" y="568" width="71" height="14" />
