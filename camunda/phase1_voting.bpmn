      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_AddVote_di" bpmnElement="Activity_AddVote">
        <dc:Bounds x="650" y="510" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_1hpsdy1_di" bpmnElement="Gateway_Merge" isMarkerVisible="true">
        <dc:Bounds x="445" y="525" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="238" y="550" />
        <di:waypoint x="290" y="550" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="390" y="550" />
